# Database (SQLite via better-sqlite3). Workspace lives under .constella/
DATABASE_URL=file:./.constella/constella.db

# better-auth
BETTER_AUTH_SECRET=replace-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Run mode: start | auth | vps | portable
CONSTELLA_RUN_MODE=start

# Runtime root for org workspaces. In dev, keep it inside the project so it's
# easy to inspect/wipe. Unset in real installs → defaults to ~/.constella.
CONSTELLA_HOME=./.constella

# Vault encryption key (for provider API keys / PATs at rest)
CONSTELLA_VAULT_KEY=replace-with-32-byte-base64-key

# Shared secret guarding the headless worker endpoints (/api/cron/tick, /api/sync/file).
# Required if you run `npm run worker` — the endpoints reject all requests when unset.
CONSTELLA_WORKER_SECRET=replace-with-a-random-string
